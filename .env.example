# =========================================================
# Переменные окружения для docker-compose
# Скопируйте этот файл в .env и заполните значениями
# =========================================================

# --- PostgreSQL ---
# Пароль для суперпользователя postgres
POSTGRES_PASSWORD=your_postgres_password
# Имя пользователя БД для приложения
POSTGRES_USER=prac_user
# Имя базы данных
POSTGRES_DB=prac
# Пароль пользователя приложения
POSTGRES_APP_PASSWORD=your_app_password

# --- Бэкенд ---
# Порт, на котором слушает бэкенд внутри контейнера
PORT=3000
# Драйвер БД: postgres или mongodb
DATABASE_DRIVER=postgres
# Хост базы данных — имя сервиса из docker-compose
DATABASE_HOST=database
# Порт базы данных
DATABASE_PORT=5432
# Логин пользователя БД
DATABASE_USERNAME=prac_user
# Пароль пользователя БД
DATABASE_PASSWORD=prac_password
# Имя базы данных
DATABASE_NAME=prac
# Формат логов backend-контейнера.
# Это значение будет прочитано приложением во время запуска контейнера.
# Варианты: dev (форматированная консоль, для локальной разработки), json, tskv
# Для сервера обычно выбирают json или tskv.
LOGGER_TYPE=json
# Режим отладки (можно оставить пустым или *)
DEBUG=

# --- pgAdmin (опционально) ---
# Email для входа в pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
# Пароль для входа в pgAdmin
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password
